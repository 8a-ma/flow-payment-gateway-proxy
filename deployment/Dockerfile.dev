FROM node:23-alpine3.20

# Instalamos dependencias necesarias para binarios de node
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copiamos package.json primero para aprovechar el cache de capas
COPY package*.json ./

# Instalamos TODAS las dependencias (incluyendo nodemon)
RUN npm install

# Copiamos el resto del proyecto
COPY . .

# Exponemos el puerto de la app
EXPOSE 8080

# En desarrollo, corremos como root o aseguramos que el volumen tenga permisos
# Por simplicidad en dev, usaremos el usuario por defecto de node o root
CMD ["npm", "run", "dev"]